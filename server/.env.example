# ============================================
# CAS Server Environment Configuration
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/cas_db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AI Provider (openai | groq | deepseek)
AI_PROVIDER=groq
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key

# Risk Engine Defaults
PROXIMITY_THRESHOLD_METERS=500
CRITICAL_DISTANCE_METERS=20
PROXIMITY_ALERT_METERS=10
GPS_UPDATE_INTERVAL_MS=3000

# Risk Weight Configuration
WEIGHT_PROXIMITY=0.35
WEIGHT_RELATIVE_SPEED=0.30
WEIGHT_DIRECTION_ALIGNMENT=0.20
WEIGHT_ACCELERATION=0.15

# Socket.IO
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
